                "alignment": "left",
                "type_preset": "h1"
              }
            },
            "text_sub": {
              "type": "text",
              "settings": {
                "text": "<p>Premium scents for men, women, and unisex tastes. Discover long-lasting fragrances made for day and night.</p>",
