      "type": "section",
      "blocks": {
        "promo_text": {
          "type": "text",
          "settings": {
            "text": "<div class='miami-promo-strip'><div class='miami-promo-item'><strong>FREE SHIPPING</strong><span>On U.S. orders over $75</span></div><div class='miami-promo-item'><strong>NEW DROPS WEEKLY</strong><span>Limited fragrances and gift sets</span></div><div class='miami-promo-item'><strong>BUY NOW PAY LATER</strong><span>Flexible payment options at checkout</span></div></div>",
            "type_preset": "rte",
            "alignment": "center",
            "width": "100%"
          }
        }
      },
      "block_order": ["promo_text"],
      "settings": {
        "content_direction": "column",
        "horizontal_alignment_flex_direction_column": "center",
        "vertical_alignment_flex_direction_column": "center",
        "gap": 8,
        "section_width": "page-width",
        "color_scheme": "scheme-1",
        "background_media": "none",
        "border": "none",
        "padding-block-start": 10,
        "padding-block-end": 10
