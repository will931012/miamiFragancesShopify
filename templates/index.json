    "why_choose": {
      "type": "section",
      "blocks": {
        "heading": {
          "type": "text",
          "settings": {
            "text": "<h2>Why choose us</h2>",
            "type_preset": "h3",
            "alignment": "center",
            "width": "fit-content"
          }
        },
        "body": {
          "type": "text",
          "settings": {
            "text": "<div class='miami-feature-grid'><div class='miami-feature-card'><strong>Long-lasting scents</strong><span>Perfume profiles designed to stay noticeable from day to night.</span></div><div class='miami-feature-card'><strong>Premium ingredients</strong><span>Refined blends crafted for smooth projection and balanced dry down.</span></div><div class='miami-feature-card'><strong>Secure checkout</strong><span>Safe payments and clear order tracking from purchase to delivery.</span></div><div class='miami-feature-card'><strong>Fast shipping</strong><span>Reliable fulfillment across the U.S. with transparent updates.</span></div></div>",
            "type_preset": "rte",
            "alignment": "center",
            "width": "100%",
            "max_width": "normal"
          }
        }
      },
      "block_order": ["heading", "body"],
