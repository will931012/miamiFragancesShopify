            "alignment": "center",
            "width": "fit-content"
          }
        },
        "quotes": {
          "type": "text",
          "settings": {
            "text": "<div class='miami-testimonials'><div class='miami-testimonial'><p>\"My new signature scent. Clean, warm, and it lasts all day.\"</p><p><strong>- Andrea M.</strong></p></div><div class='miami-testimonial'><p>\"The packaging and fragrance quality feel premium at a great price.\"</p><p><strong>- Kevin R.</strong></p></div><div class='miami-testimonial'><p>\"Fast shipping and amazing customer service. I ordered again.\"</p><p><strong>- Valeria C.</strong></p></div></div>",
            "type_preset": "rte",
            "alignment": "center",
            "width": "100%"
          }
        }
